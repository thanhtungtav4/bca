# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors
.vscode/
.idea/
*.swp
*.swo

# Node (nếu sau này thêm build tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env / secrets
.env
.env.local
.env.*.local

# OS thumbnails (do Figma mount)
.thumbnail

# WordPress core + runtime (KHÔNG track)
# Track work product dưới đây (chỉ track theme code + mu-plugins + ACF JSON)

# WP core files
wp/wp-admin/
wp/wp-includes/
wp/*.php
wp/license.txt
wp/readme.html

# Local env config
wp-config.php
wp-config-local.php
.htaccess

# WP runtime data
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/debug.log
wp-content/debug-acf.php
wp-content/plugins/                       # plugins install qua WP admin (không commit)

# Theme build artifacts (chỉ track source)
wp-content/themes/*/node_modules/
wp-content/themes/*/vendor/
wp-content/themes/*/package-lock.json

# Local env config
.deploy.env
.deploy.env.example
