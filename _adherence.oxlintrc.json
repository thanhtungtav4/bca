{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/icons/**",
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "components/layout/**",
              "components/marketing/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|name|size|shape|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: photo, name, size, shape, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:square|circle)$/]",
        "message": "<Avatar> shape must be one of 'square' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|tone|as|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, tone, as, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filled|line|ghost)$/]",
        "message": "<Button> variant must be one of 'filled' | 'line' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<Button> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClientInfoItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|name|detail|align|style|key|ref|className|style|children)$/]",
        "message": "<ClientInfoItem> doesn't accept that prop. Declared props: logo, name, detail, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClientInfoItem'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<ClientInfoItem> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClientLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|name|width|height|style|key|ref|className|style|children)$/]",
        "message": "<ClientLogo> doesn't accept that prop. Declared props: logo, name, width, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Component1'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|type|icon|tone|key|ref|className|style|children)$/]",
        "message": "<Component1> doesn't accept that prop. Declared props: children, type, icon, tone."
      },
