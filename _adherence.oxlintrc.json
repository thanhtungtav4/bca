        "selector": "JSXOpeningElement[name.name='Component1'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:ghost|line|filled)$/]",
        "message": "<Component1> type must be one of 'ghost' | 'line' | 'filled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Component1'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
